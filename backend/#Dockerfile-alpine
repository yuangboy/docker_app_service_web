# ==========================================
# 1. ÉTAPE DE CONFIGURATION & DEPENDANCES (Build)
# ==========================================
FROM node:20-alpine AS builder

WORKDIR /app

# Copie des fichiers de dépendances
COPY package*.json ./

# Installation propre des dépendances (y compris de dev pour le build)
# RUN npm ci
RUN npm install --legacy-peer-deps --registry=https://registry.npmmirror.com

# Copie du reste du code source
COPY . .

# Construction de l'application (génère le dossier /dist)
# RUN npm run build
RUN npm run build

