# ==========================================
# 1. ÉTAPE DE BUILD (Compilation)
# ==========================================
FROM node:20-alpine AS builder

WORKDIR /app

# Copie des fichiers de configuration et dépendances
COPY package*.json ./
COPY postcss.config.mjs ./

# Installation propre de TOUTES les dépendances (y compris de dev pour le build)
RUN npm ci

# Copie du reste du code source
COPY . .

# Allocation de mémoire indispensable pour la compilation de Tailwind v4 / Next.js
ENV NODE_OPTIONS="--max-old-space-size=4096"

# Nettoyage des anciens builds et déclenchement de la compilation (.next)
RUN rm -rf .next .cache && npm run build

# Nettoyage des dépendances de développement pour alléger l'image finale
RUN npm prune --production


