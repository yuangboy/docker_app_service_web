# ============================================
# APPLICATION
# ============================================
NODE_ENV=development
APP_NAME=MonAppFullStack
APP_VERSION=1.0.0

# ============================================
# BASES DE DONNÉES
# ============================================

# PostgreSQL (Relationnelle)
# POSTGRES_USER=appuser
# POSTGRES_PASSWORD=SecurePostgresP@ss2024!
# POSTGRES_DB=appdb
# DATABASE_URL=postgresql://appuser:SecurePostgresP@ss2024!@postgres:5432/appdb

# MongoDB (NoSQL)
MONGO_ROOT_USER=albin
MONGO_ROOT_PASSWORD=password
MONGO_DB=appdb
MONGODB_URI=mongodb://albin:password@mongodb:27017/appdb?authSource=admin
MONGODB_DB=appdb

# ============================================
# CACHE & SESSIONS
# ============================================
REDIS_PASSWORD=SecureRedisP@ss2024!
REDIS_URL=redis://:SecureRedisP@ss2024!@redis:6379

# ============================================
# SÉCURITÉ
# ============================================
JWT_SECRET=759453a1f0b677482311f1b0ddfdd69b25ea0b402b5c077

JWT_EXPIRATION=7d
BCRYPT_ROUNDS=10

# ============================================
# INTERFACES D'ADMINISTRATION
# ============================================
# MongoDB Express
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASSWORD=admin123

# pgAdmin
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin123

# ============================================
# EMAILS (optionnel)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@yourapp.com

# ============================================
# AUTRES
# ============================================
TZ=Europe/Paris
CORS_ORIGIN=http://localhost,https://votre-domaine.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# CORS & API
# ============================================
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# ============================================
# PORTS
# ============================================
FRONTEND_PORT=3000
BACKEND_PORT=3001
NGINX_PORT=80
MONGODB_PORT=27017

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=debug